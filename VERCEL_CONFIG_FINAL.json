{
  "version": 2,
  "name": "fahamu-shamba",
  "public": true,
  "env": {
    "NODE_ENV": "production",
    "PORT": "3001"
  },
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb",
        "nodeVersion": "18.x"
      }
    },
    {
      "src": "backend/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/server.js",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "/admin(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/login",
      "dest": "/backend/server.js"
    },
    {
      "src": "/farmer-dashboard",
      "dest": "/backend/server.js"
    },
    {
      "src": "/farmer-profile",
      "dest": "/backend/server.js"
    },
    {
      "src": "/dashboard",
      "dest": "/backend/server.js"
    },
    {
      "src": "/crop-prediction",
      "dest": "/backend/server.js"
    },
    {
      "src": "/market-trends",
      "dest": "/backend/server.js"
    },
    {
      "src": "/recommendations",
      "dest": "/backend/server.js"
    },
    {
      "src": "/feedback",
      "dest": "/backend/server.js"
    },
    {
      "src": "/community",
      "dest": "/backend/server.js"
    },
    {
      "src": "/settings",
      "dest": "/backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/backend/public/$1"
    }
  ],
  "functions": {
    "backend/server.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
